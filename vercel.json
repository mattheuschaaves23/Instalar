{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd bem-instalado/frontend && npm install && npm run build",
  "outputDirectory": "bem-instalado/frontend/build",
  "installCommand": "cd bem-instalado/backend && npm install && cd ../frontend && npm install",
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
