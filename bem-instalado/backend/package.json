{
  "name": "bem-instalado-backend",
  "version": "1.0.0",
  "private": true,
  "main": "server.js",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "nodemon server.js",
    "db:init": "node scripts/initDatabase.js",
    "db:migrate": "node scripts/migrateDatabase.js",
    "db:migrate:deploy": "node scripts/migrateDatabase.js",
    "admin:promote": "node scripts/promoteAdmin.js",
    "seed:demo": "node scripts/seedDemoData.js",
    "seed:demo:clear": "node scripts/seedDemoData.js --clear",
    "test:papelperto": "node ../scripts/verifyPapelPertoIntegration.js",
    "test": "node --test --test-concurrency=1 test/*.test.js",
    "test:integration": "node --test test/marketplace.integration.test.js",
    "start": "npm run db:init && npm run db:migrate && node server.js",
    "build:web": "node -e \"const fs=require('fs');const path=require('path');fs.rmSync(path.resolve(process.cwd(),'..','frontend','build'),{recursive:true,force:true});\" && npm --prefix ../frontend install && npm --prefix ../frontend run build"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.15.0",
    "pg": "^8.13.1",
    "qrcode": "^1.5.4",
    "@vercel/blob": "^2.6.1",
    "multer": "^2.2.0",
    "speakeasy": "^2.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
